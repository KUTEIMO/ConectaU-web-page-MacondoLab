# Variables de Entorno para Producción - Firebase
# Copia este archivo como .env.production y completa con tus credenciales

# Obtén estas credenciales de Firebase Console:
# https://console.firebase.google.com/
# Configuración del proyecto > Configuración general > Tus aplicaciones > Web

# ⚠️ IMPORTANTE: Reemplaza con tus valores reales (NUNCA compartas estas credenciales)
VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_project_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
VITE_FIREBASE_APP_ID=tu_app_id
VITE_FIREBASE_DATABASE_URL=https://tu_proyecto-default-rtdb.firebaseio.com

# URL de descarga del APK (Opcional)
# Si no se define, se usará la URL por defecto en src/constants/downloads.ts
# Ejemplo: https://storage.googleapis.com/mi-bucket/app.apk
VITE_APK_URL=

# Instrucciones:
# 1. Copia este archivo como .env.production
# 2. Reemplaza todos los valores con los reales de tu proyecto Firebase
# 3. NUNCA hagas commit de este archivo con credenciales reales
# 4. El archivo .env.production está protegido por .gitignore
