{
  "name": "conectau-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "seed:conversations": "node scripts/backfill-conversations.js",
    "pre-deploy": "powershell -ExecutionPolicy Bypass -File scripts\\verificar-pre-deploy.ps1",
    "deploy": "npm run build:prod && firebase deploy --only hosting",
    "deploy:all": "npm run build:prod && firebase deploy --only hosting,firestore:rules,storage",
    "deploy:hosting": "npm run build:prod && firebase deploy --only hosting",
    "deploy:firestore": "firebase deploy --only firestore:rules",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:full": "powershell -ExecutionPolicy Bypass -File scripts\\deploy-produccion.ps1"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.0.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.2",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
